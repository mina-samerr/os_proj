#classes
class Process:
    def __init__(self, pid, arrival, burst):
        self.pid = pid
        self.arrival = arrival
        self.burst = burst
        self.remaining = burst

        self.completion = 0
        self.turnaround = 0
        self.waiting = 0
        self.response = -1  

#at&bt as input
def input_processes():
    n = int(input("Enter number of processes: "))
    processes = []

    for i in range(n):
        at = int(input(f"P{i+1} Arrival Time: "))
        bt = int(input(f"P{i+1} Burst Time: "))

        processes.append(Process(i+1, at, bt))

    return processes

#srtf model 
def srtf(processes):
    time = 0
    completed = 0
    n = len(processes)
    gantt = []

    while completed < n:
        available = [p for p in processes if p.arrival <= time and p.remaining > 0]

        if not available:
            time += 1
            continue

        current = min(available, key=lambda x: x.remaining)

        if current.response == -1:
            current.response = time - current.arrival

        gantt.append(current.pid)

        current.remaining -= 1
        time += 1

        if current.remaining == 0:
            current.completion = time
            completed += 1

    return gantt

#rr model 
from collections import deque

def round_robin(processes, quantum):
    time = 0
    queue = deque()
    gantt = []
    processes.sort(key=lambda x: x.arrival)

    i = 0
    n = len(processes)

    while i < n or queue:
        while i < n and processes[i].arrival <= time:
            queue.append(processes[i])
            i += 1

        if not queue:
            time += 1
            continue

        current = queue.popleft()

        if current.response == -1:
            current.response = time - current.arrival

        exec_time = min(quantum, current.remaining)

        for _ in range(exec_time):
            gantt.append(current.pid)
            time += 1

            while i < n and processes[i].arrival <= time:
                queue.append(processes[i])
                i += 1

        current.remaining -= exec_time

        if current.remaining > 0:
            queue.append(current)
        else:
            current.completion = time

    return gantt

def calc_metrics(processes):
    for p in processes:
        p.turnaround = p.completion - p.arrival
        p.waiting = p.turnaround - p.burst

#bar bta3 el process
def print_gantt(gantt):
    print("Gantt Chart:")
    print(" | ".join(f"P{p}" for p in gantt))

def print_results(processes):
    print("\nPID | AT | BT | CT | TAT | WT | RT")

    for p in processes:
        print(f"{p.pid}   | {p.arrival}  | {p.burst}  | {p.completion}  | {p.turnaround}  | {p.waiting}  | {p.response}")

    avg_wt = sum(p.waiting for p in processes) / len(processes)
    avg_tat = sum(p.turnaround for p in processes) / len(processes)

    print(f"\nAverage WT = {avg_wt}")
    print(f"Average TAT = {avg_tat}")

procs = input_processes()

import copy
srtf_procs = copy.deepcopy(procs)
rr_procs = copy.deepcopy(procs)

g1 = srtf(srtf_procs)
calc_metrics(srtf_procs)

q = int(input("Enter Quantum: "))
g2 = round_robin(rr_procs, q)
calc_metrics(rr_procs)

print("\n--- SRTF ---")
print_gantt(g1)
print_results(srtf_procs)

print("\n--- Round Robin ---")
print_gantt(g2)
print_results(rr_procs)

import tkinter as tk
from tkinter import ttk, messagebox
import copy


def run_algorithms():
    try:
        n = int(entry_n.get())
        quantum = int(entry_q.get())

        processes = []

        for i in range(n):
            at = int(entries[i][0].get())
            bt = int(entries[i][1].get())
            processes.append(Process(i+1, at, bt))

        srtf_procs = copy.deepcopy(processes)
        rr_procs = copy.deepcopy(processes)

        g1 = srtf(srtf_procs)
        calc_metrics(srtf_procs)

        g2 = round_robin(rr_procs, quantum)
        calc_metrics(rr_procs)

        show_results(srtf_procs, rr_procs, g1, g2)

    except:
        messagebox.showerror("Error", "Invalid Input")

def show_results(srtf_procs, rr_procs, g1, g2):

    for row in tree.get_children():
        tree.delete(row)

    for i in range(len(srtf_procs)):
        tree.insert("", "end", values=(
            f"P{i+1}",
            srtf_procs[i].waiting,
            srtf_procs[i].turnaround,
            rr_procs[i].waiting,
            rr_procs[i].turnaround
        ))

    avg_srtf_wt = sum(p.waiting for p in srtf_procs)/len(srtf_procs)
    avg_rr_wt = sum(p.waiting for p in rr_procs)/len(rr_procs)

    label_avg.config(text=f"Avg WT → SRTF: {avg_srtf_wt:.2f} | RR: {avg_rr_wt:.2f}")

    gantt_srtf.config(text="SRTF: " + " | ".join(f"P{p}" for p in g1))
    gantt_rr.config(text="RR: " + " | ".join(f"P{p}" for p in g2))


def create_inputs():
    try:
        n = int(entry_n.get())

        for widget in frame_inputs.winfo_children():
            widget.destroy()

        global entries
        entries = []

        for i in range(n):
            tk.Label(frame_inputs, text=f"P{i+1}", bg="#1e1e2f", fg="white").grid(row=i, column=0)

            at = tk.Entry(frame_inputs, width=5)
            bt = tk.Entry(frame_inputs, width=5)

            at.grid(row=i, column=1, padx=5)
            bt.grid(row=i, column=2, padx=5)

            entries.append((at, bt))

    except:
        messagebox.showerror("Error", "Enter valid number")

