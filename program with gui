from collections import deque
import copy


#classes
class Process:
    def __init__(self, pid, arrival, burst):
        self.pid = pid
        self.arrival = arrival
        self.burst = burst
        self.remaining = burst

        self.completion = 0
        self.turnaround = 0
        self.waiting = 0
        self.response = -1


#srtf
def srtf(processes):

    time = 0
    completed = 0
    n = len(processes)

    gantt = []

    while completed < n:

        available = [
            p for p in processes
            if p.arrival <= time and p.remaining > 0
        ]

        # CPU IDLE
        if not available:
            gantt.append("Idle")
            time += 1
            continue

        #el 7eta bta3t el tie
        current = min(
            available,
            key=lambda x: (x.remaining, x.arrival, x.pid)
        )

        if current.response == -1:
            current.response = time - current.arrival

        gantt.append(f"P{current.pid}")

        current.remaining -= 1
        time += 1

        if current.remaining == 0:
            current.completion = time
            completed += 1

    return gantt


#rr
def round_robin(processes, quantum):

    time = 0
    queue = deque()

    gantt = []

    processes.sort(key=lambda x: x.arrival)

    i = 0
    n = len(processes)

    while i < n or queue:

        while i < n and processes[i].arrival <= time:
            queue.append(processes[i])
            i += 1

        if not queue:
            gantt.append("Idle")
            time += 1
            continue

        current = queue.popleft()

        if current.response == -1:
            current.response = time - current.arrival

        exec_time = min(quantum, current.remaining)

        for _ in range(exec_time):

            gantt.append(f"P{current.pid}")

            time += 1

            while i < n and processes[i].arrival <= time:
                queue.append(processes[i])
                i += 1

        current.remaining -= exec_time

        if current.remaining > 0:
            queue.append(current)

        else:
            current.completion = time

    return gantt


def calc_metrics(processes):

    for p in processes:

        p.turnaround = p.completion - p.arrival

        p.waiting = p.turnaround - p.burst



def format_gantt(gantt):

    result = "0 "

    for i, p in enumerate(gantt):
        result += f"| {p} | {i+1} "

    return result



def run_algorithms():

    try:

        n = int(entry_n.get())
        quantum = int(entry_q.get())

        # Validation
        if n <= 0:
            raise ValueError

        if quantum <= 0:
            raise ValueError

        processes = []

        for i in range(n):

            at_text = entries[i][0].get()
            bt_text = entries[i][1].get()

            if at_text == "" or bt_text == "":
                raise ValueError

            at = int(at_text)
            bt = int(bt_text)

            if at < 0 or bt <= 0:
                raise ValueError

            processes.append(Process(i + 1, at, bt))

        srtf_procs = copy.deepcopy(processes)
        rr_procs = copy.deepcopy(processes)

        g1 = srtf(srtf_procs)
        calc_metrics(srtf_procs)

        g2 = round_robin(rr_procs, quantum)
        calc_metrics(rr_procs)

        show_results(
            srtf_procs,
            rr_procs,
            g1,
            g2
        )

    except:
        messagebox.showerror(
            "Error",
            "Please enter valid positive numbers"
        )



def show_results(srtf_procs, rr_procs, g1, g2):

    for row in tree.get_children():
        tree.delete(row)

    for i in range(len(srtf_procs)):

        tree.insert("", "end", values=(

            f"P{i+1}",

            srtf_procs[i].completion,
            srtf_procs[i].turnaround,
            srtf_procs[i].waiting,
            srtf_procs[i].response,

            rr_procs[i].completion,
            rr_procs[i].turnaround,
            rr_procs[i].waiting,
            rr_procs[i].response
        ))

  

    avg_srtf_wt = sum(p.waiting for p in srtf_procs) / len(srtf_procs)
    avg_srtf_tat = sum(p.turnaround for p in srtf_procs) / len(srtf_procs)
    avg_srtf_rt = sum(p.response for p in srtf_procs) / len(srtf_procs)

    avg_rr_wt = sum(p.waiting for p in rr_procs) / len(rr_procs)
    avg_rr_tat = sum(p.turnaround for p in rr_procs) / len(rr_procs)
    avg_rr_rt = sum(p.response for p in rr_procs) / len(rr_procs)

    label_avg.config(
        text=
        f"SRTF → WT={avg_srtf_wt:.2f} | "
        f"TAT={avg_srtf_tat:.2f} | "
        f"RT={avg_srtf_rt:.2f}\n"
        f"RR → WT={avg_rr_wt:.2f} | "
        f"TAT={avg_rr_tat:.2f} | "
        f"RT={avg_rr_rt:.2f}"
    )

    gantt_srtf.config(
        text="SRTF Gantt:\n" + format_gantt(g1)
    )

    gantt_rr.config(
        text="RR Gantt:\n" + format_gantt(g2)
    )



def create_inputs():

    try:

        n = int(entry_n.get())

        if n <= 0:
            raise ValueError

        # Clear Old Inputs
        for widget in frame_inputs.winfo_children():
            widget.destroy()

        global entries
        entries = []

        tk.Label(
            frame_inputs,
            text="Process",
            bg="#1e1e2f",
            fg="cyan"
        ).grid(row=0, column=0)

        tk.Label(
            frame_inputs,
            text="Arrival",
            bg="#1e1e2f",
            fg="cyan"
        ).grid(row=0, column=1)

        tk.Label(
            frame_inputs,
            text="Burst",
            bg="#1e1e2f",
            fg="cyan"
        ).grid(row=0, column=2)

        for i in range(n):

            tk.Label(
                frame_inputs,
                text=f"P{i+1}",
                bg="#1e1e2f",
                fg="white"
            ).grid(row=i+1, column=0, pady=3)

            at = tk.Entry(frame_inputs, width=8)
            bt = tk.Entry(frame_inputs, width=8)

            at.grid(row=i+1, column=1, padx=5)
            bt.grid(row=i+1, column=2, padx=5)

            entries.append((at, bt))

    except:
        messagebox.showerror(
            "Error",
            "Enter valid number of processes"
        )


